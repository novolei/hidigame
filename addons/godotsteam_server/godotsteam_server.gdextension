[configuration]
entry_symbol = "godotsteam_server_init"
compatibility_minimum = 4.1

[libraries]
android.debug.arm64 = "res://addons/godotsteam_server/androidarm64/libgodotsteam_server.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/godotsteam_server/androidarm64/libgodotsteam_server.android.template_release.arm64.so"
linux.debug.arm64 = "res://addons/godotsteam_server/linuxarm64/libgodotsteam_server.linux.template_debug.arm64.so"
linux.debug.x86_64 = "res://addons/godotsteam_server/linux64/libgodotsteam_server.linux.template_debug.x86_64.so"
linux.debug.x86_32 = "res://addons/godotsteam_server/linux32/libgodotsteam_server.linux.template_debug.x86_32.so"
linux.release.arm64 = "res://addons/godotsteam_server/linuxarm64/libgodotsteam_server.linux.template_release.arm64.so"
linux.release.x86_64 = "res://addons/godotsteam_server/linux64/libgodotsteam_server.linux.template_release.x86_64.so"
linux.release.x86_32 = "res://addons/godotsteam_server/linux32/libgodotsteam_server.linux.template_release.x86_32.so"
macos.debug = "res://addons/godotsteam_server/osx/libgodotsteam_server.macos.template_debug.dylib"
macos.release = "res://addons/godotsteam_server/osx/libgodotsteam_server.macos.template_release.dylib"
windows.debug.x86_64 = "res://addons/godotsteam_server/win64/libgodotsteam_server.windows.template_debug.x86_64.dll"
windows.debug.x86_32 = "res://addons/godotsteam_server/win32/libgodotsteam_server.windows.template_debug.x86_32.dll"
windows.release.x86_64 = "res://addons/godotsteam_server/win64/libgodotsteam_server.windows.template_release.x86_64.dll"
windows.release.x86_32 = "res://addons/godotsteam_server/win32/libgodotsteam_server.windows.template_release.x86_32.dll"

[dependencies]
android.arm64 = { "res://addons/godotsteam_server/androidarm64/libsteam_api.so": "" }
linux.arm64 = { "res://addons/godotsteam_server/linuxarm64/libsteam_api.so": "" }
linux.x86_64 = { "res://addons/godotsteam_server/linux64/libsteam_api.so": "" }
linux.x86_32 = { "res://addons/godotsteam_server/linux32/libsteam_api.so": "" }
macos.universal = { "res://addons/godotsteam_server/osx/libsteam_api.dylib": "" }
windows.x86_64 = { "res://addons/godotsteam_server/win64/steam_api64.dll": "" }
windows.x86_32 = { "res://addons/godotsteam_server/win32/steam_api.dll": "" }