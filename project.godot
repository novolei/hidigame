[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Monster & Hunter"
config/description="This is a foundational template for a 3D multiplayer game, developed in Godot Engine."
config/version="0.4.15"
config/tags=PackedStringArray("3d", "network")
run/main_scene="res://scenes/ui/startup.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.1764706, 0.56078434, 0.9882353, 1)
boot_splash/show_image=false
config/icon="res://icon.png"
boot_splash/minimum_display_time=0.0
boot_splash+/timing/minimum_display_time_seconds=0.0
boot_splash+/timing/fade_in_time=0.08
boot_splash+/timing/fade_out_time=0.28
